# Copy to .env and fill in real values. .env is gitignored.

# ── Required for the real LLM pipeline (agents + worktree + commit + push)
# ──────────────────────────────────────────────────────────────────────────
# Without ALL of: OPENROUTER_API_KEY + TELEGRAM_BOT_TOKEN +
# TELEGRAM_OWNER_CHAT_ID + REPO_PATH the bot falls back to the simple stub
# that just acknowledges messages without running agents.

OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Telegram bot (Module 7).
# Get token from @BotFather, your chat_id from @userinfobot.
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_OWNER_CHAT_ID=123456789

# Path to the git repository the agents will work on.
# Must exist, must be a git repo (have a .git/ subdir), and have a "main"
# branch as the base. The bot creates feature/<task_id> worktrees off this.
# Example: REPO_PATH=/Users/you/sandbox-project
REPO_PATH=/Users/you/sandbox-project

# ── Optional ───────────────────────────────────────────────────────────────

# Voice messages (OpenAI Whisper, ~$0.006/min).
OPENAI_API_KEY=sk-REPLACE_ME

# Custom worktree root (default: /tmp/aidt_worktrees).
# WORKTREE_ROOT=/Users/you/aidt_worktrees

# Persist tier-session choices across bot restarts (Step 19).
# Set to a directory the bot can write to; tier_sessions.json is created there.
# Without this, every restart forgets which tier each chat picked.
# BOT_STATE_DIR=/Users/you/.ai-dev-team

# Cost-confirmation threshold in USD (default 1.0).
# BOT_COST_THRESHOLD_USD=1.0

# Enable opt-in real-LLM integration tests.
# AI_DEV_TEAM_REAL_LLM=1
