# Copy to .env and fill in real values. .env is gitignored.

# Required for any pipeline run that reaches the cloud agents.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Telegram bot (Module 7).
# Get token from @BotFather, your chat_id from @userinfobot.
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_BOTFATHER_TOKEN
TELEGRAM_OWNER_CHAT_ID=123456789

# Optional: enables voice messages (OpenAI Whisper, ~$0.006/min).
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: cost-confirmation threshold in USD (default 1.0).
# BOT_COST_THRESHOLD_USD=1.0

# Optional: enable opt-in real-LLM integration tests.
# AI_DEV_TEAM_REAL_LLM=1
