# Copy to .env and fill in real values. .env is gitignored.

# ── Canonical shared runtime env ───────────────────────────────────────────
# Primary SQLite persistence path used by both Telegram and Web runtimes.
# Stores tier sessions, task history, budget state, project registry,
# project team state, approvals, and project threads.
# STATE_DB_PATH=/Users/you/.ai-dev-team/state.db

# Optional observability JSONL sink for progress / cost snapshots.
# OBS_LOG_PATH=/Users/you/.ai-dev-team/obs.jsonl

# Optional logging override for scripts/run_telegram_bot.py.
# LOG_LEVEL=INFO

# ── Canonical bot runtime env ──────────────────────────────────────────────
# Without OPENROUTER_API_KEY and at least one routable project runtime,
# the bot still starts, but only in the simple acknowledgement mode
# instead of the real multi-agent pipeline.

OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Coordinator / single-bot compatibility token from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_BOTFATHER_TOKEN

# Canonical multi-bot runtime contract for role-specific bot identities.
# Format: <agent_role>=<TOKEN_ENV_KEY>, comma-separated.
# Example:
# TELEGRAM_AGENT_TOKENS=coordinator_agent=TELEGRAM_BOT_TOKEN,writer_agent=TELEGRAM_WRITER_BOT_TOKEN,reviewer_agent=TELEGRAM_REVIEWER_BOT_TOKEN
#
# Important:
# - this string stores env-var names, not raw tokens
# - when this variable is present, the Telegram entrypoint can start one PTB
#   Application per configured identity
# - startup now probes every configured identity via Telegram API before the
#   bot is considered reachable/started
# - outbound replies now use role-aware bot identity selection with
#   coordinator fallback when a specific identity is unavailable
# - bound project chats can now emit agent lifecycle progress from the
#   matching bot identity when that sender exists
# - owner private DMs now stay on the same bot identity thread the owner used
# - secondary group inbound is still disabled and remains
#   `secondary_bot_inbound_not_enabled`
# TELEGRAM_AGENT_TOKENS=coordinator_agent=TELEGRAM_BOT_TOKEN
#
# Example referenced token env vars:
# TELEGRAM_WRITER_BOT_TOKEN=1234567890:REPLACE_WITH_WRITER_BOT_TOKEN
# TELEGRAM_REVIEWER_BOT_TOKEN=1234567890:REPLACE_WITH_REVIEWER_BOT_TOKEN

# Numeric Telegram chat id allowed to control the bot.
# You can get it from @userinfobot.
TELEGRAM_OWNER_CHAT_ID=123456789

# Confirmation threshold in USD for expensive tasks. Default: 1.0
# BOT_COST_THRESHOLD_USD=1.0

# OPENAI_API_KEY is optional and currently enables Whisper voice transcription.
# OPENAI_API_KEY=sk-REPLACE_ME

# ── Canonical web runtime env ──────────────────────────────────────────────
# Web Office uses the same STATE_DB_PATH contract as the bot runtime.
# There are no additional canonical web-only env keys yet in C0.1.

# ── Legacy compatibility / bootstrap env ──────────────────────────────────
# BOT_STATE_DIR remains compatibility-only. If STATE_DB_PATH is unset,
# the runtime falls back to BOT_STATE_DIR/state.db.
# Existing BOT_STATE_DIR/tier_sessions.json is still migrated on startup
# when a writable StateDB is available.
# BOT_STATE_DIR=/Users/you/.ai-dev-team

# Legacy single-project bootstrap seed. Used only when the persisted
# project registry does not already supply a routable project runtime.
REPO_PATH=/Users/you/sandbox-project

# Legacy bootstrap override for git worktree root.
# Default: system temp dir / aidt_worktrees
# WORKTREE_ROOT=/Users/you/aidt_worktrees

# ── Optional test / developer flags ────────────────────────────────────────

# Enable opt-in real OpenRouter integration tests.
# AI_DEV_TEAM_REAL_LLM=1
