# Copy to .env and fill in real values. .env is gitignored.

# ── Required for the real LLM pipeline ─────────────────────────────────────
# Without OPENROUTER_API_KEY and one active project with a valid runtime
# binding, the bot still starts, but only in the simple acknowledgement mode
# instead of the real multi-agent pipeline.

OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_BOTFATHER_TOKEN

# Numeric Telegram chat id allowed to control the bot.
# You can get it from @userinfobot.
TELEGRAM_OWNER_CHAT_ID=123456789

# Legacy bootstrap/fallback path to the git repository the agents will modify.
# Used only when StateDB does not already contain one active project runtime
# binding. Must exist, must be a git repo, and should have main checked out.
# In the current single-project mode, if StateDB already contains multiple
# projects, the builder will NOT auto-select one from REPO_PATH.
# Example: REPO_PATH=/Users/you/sandbox-project
REPO_PATH=/Users/you/sandbox-project

# ── Optional features ──────────────────────────────────────────────────────

# Voice input via OpenAI Whisper.
# OPENAI_API_KEY=sk-REPLACE_ME

# Legacy bootstrap override for the git worktree root.
# Default: system temp dir / aidt_worktrees
# WORKTREE_ROOT=/Users/you/aidt_worktrees

# Primary SQLite persistence path.
# Stores tier sessions, task history, budget state, and project registry data.
# Default resolution order:
#   1. STATE_DB_PATH
#   2. BOT_STATE_DIR/state.db
#   3. ~/.ai-dev-team/state.db
# STATE_DB_PATH=/Users/you/.ai-dev-team/state.db

# Legacy state directory. Still supported for compatibility.
# If STATE_DB_PATH is not set, the bot uses BOT_STATE_DIR/state.db.
# Existing BOT_STATE_DIR/tier_sessions.json is migrated on startup when possible.
# BOT_STATE_DIR=/Users/you/.ai-dev-team

# Confirmation threshold in USD for expensive tasks. Default: 1.0
# BOT_COST_THRESHOLD_USD=1.0

# Observability JSONL log file for progress / cost / performance snapshots.
# OBS_LOG_PATH=/Users/you/.ai-dev-team/obs.jsonl

# Enable opt-in real OpenRouter integration tests.
# AI_DEV_TEAM_REAL_LLM=1
